#: virtinst/virtclone.py:91
msgid "Storage Configuration"
msgstr "Подешавање складишта"

#: virtinst/virtclone.py:97
msgid "New file to use as the disk image for the new guest"
msgstr "Нова датотека која ће се користити као слика диска за новог госта"

#: virtinst/virtclone.py:103
msgid ""
"Force to copy devices (eg, if 'hdc' is a readonly cdrom device, --force-"
"copy=hdc)"
msgstr ""
"Приморај копирање уређаја (нпр, ако је „hdc“ случајан диск уређај, користити "
"--force-copy=hdc)"

#: virtinst/virtclone.py:109
msgid ""
"Skip copy of the device target. (eg, if 'vda' is a disk you don't want to "
"copy and use the same path in the new VM, use --skip-copy=vda)"
msgstr ""
"Прескочи умножавање циљног уређаја. (нпр. ако је „vda“ диск који не желите "
"да умножите и користите исту путању у новој виртуелној машини, користите --"
"skip-copy=vda)"

#: virtinst/virtclone.py:119
msgid "Do not use a sparse file for the clone's disk image"
msgstr "Немој користити празну датотеку за слику клонираног диска"

#: virtinst/virtclone.py:127
msgid ""
"Do not clone storage contents to specified file paths, their contents will "
"be left untouched. This requires specifying existing paths for every "
"cloneable disk image."
msgstr ""
"Не клонирај садржаје складишта на наведене путање датотека, њихов садржај ће "
"остати нетакнут. Ово захтева навођење постојећих путања за сваки одраз диска "
"који се може клонирати."

#: virtinst/virtclone.py:134
msgid "New file to use as storage for nvram VARS"
msgstr "Нова датотека која ће се користити као складиште за nvram VARS"

#: virtinst/virtclone.py:137
msgid "Networking Configuration"
msgstr "Подешавање мреже"

#: virtinst/virtclone.py:143
msgid ""
"New fixed MAC address for the clone guest. Default is a randomly generated "
"MAC"
msgstr ""
"Нова фиксирана MAC адреса за клонираног госта. Случајно изабрана адреса је "
"подразумевана"

#: virtinst/virtclone.py:146 virtinst/virtinstall.py:1187
#: virtinst/virtxml.py:567
msgid "Miscellaneous Options"
msgstr "Разне могућности"

#: virtinst/virtclone.py:179
msgid ""
"Either --auto-clone or --file is required, use '--auto-clone or --file' and "
"try again."
msgstr ""
"Потребно је или --auto-clone или --file, користите „--auto-clone или --file“ "
"и покушајте поново."

#: virtinst/virtclone.py:215
msgid ""
"A name is required for the new virtual machine, use '--name NEW_VM_NAME' to "
"specify one."
msgstr ""
"Потребан је назив за нову виртуелну машину, користите „--name NEW_VM_NAME“ "
"да га наведете."

#: virtinst/virtclone.py:234
#, python-format
msgid "Clone '%s' created successfully."
msgstr "Клон „%s“ је успешно направљен."

#: virtinst/virtclone.py:245 virtinst/virtinstall.py:1313
msgid "Installation aborted at user request"
msgstr "Инсталацијa је обустављена на корисников захтев"

#: virtinst/virtinstall.py:59
msgid ""
"-c specified with what looks like a libvirt URI. Did you mean to use --"
"connect? If not, use --cdrom instead"
msgstr ""
"-c је наведено са нечим што личи на libvirt адресу. Да ли сте мислили да "
"користите --connect? Ако не, користите --cdrom уместо тога"

#: virtinst/virtinstall.py:128
msgid "Cannot specify storage and use --nodisks"
msgstr "Не можете навести складиште и уједно користити --nodisks"

#: virtinst/virtinstall.py:133
msgid ""
"Cannot mix --file, --nonsparse, or --file-size with --disk options. Use --"
"disk PATH[,size=SIZE][,sparse=yes|no]"
msgstr ""
"Не можете мешати опције --file, --nonsparse или --file-size са опцијом --"
"disk. Користите --disk ПУТАЊА[,size=ВЕЛИЧИНА][,sparse=yes|no]"

#: virtinst/virtinstall.py:154
msgid "--os-type is deprecated and does nothing. Please stop using it."
msgstr "--os-type је застарело и не ради ништа. Престаните да га користите."

#: virtinst/virtinstall.py:229
msgid "Cannot mix --graphics and old style graphical options"
msgstr "Не могу се мешати --graphics и старе графичке опције"

#: virtinst/virtinstall.py:233
msgid "Can't specify more than one of VNC, SDL, --graphics or --nographics"
msgstr ""
"Не може се навести више од једне ставке VNC, SDL, --graphics или --nographics"

#: virtinst/virtinstall.py:315
msgid "--memory amount in MiB is required"
msgstr "--memory вредност у MiB јединици је потребна"

#: virtinst/virtinstall.py:318
msgid "--disk storage must be specified (override with --disk none)"
msgstr "--disk складиште мора бити наведено (премостите са --disk none)"

#: virtinst/virtinstall.py:322
#, python-format
msgid ""
"An install method must be specified\n"
"(%(methods)s)"
msgstr ""
"Начин инсталирања мора бити наведен\n"
"(%(methods)s)"

#: virtinst/virtinstall.py:336
msgid ""
"CDROM media does not print to the text console by default, so you likely "
"will not see text install output. You might want to use --location."
msgstr ""
"ЦД медијум не штампа на текстуалну конзолу по подразумеваним подешавањима, "
"па вероватно нећете видети текстуални излаз инсталације. Можда ћете желети "
"да користите --location."

#: virtinst/virtinstall.py:341
msgid "See the man page for examples of using --location with CDROM media"
msgstr ""
"Погледајте ман страницу за примере коришћења заставице --location са ЦД "
"читачима"

#: virtinst/virtinstall.py:356
#, python-format
msgid ""
"Requested memory %(mem1)s MiB is less than the recommended %(mem2)s MiB for "
"OS %(osname)s"
msgstr ""
"Затражена меморија %(mem1)s MiB је мања од препоручених %(mem2)s MiB за ОС %"
"(osname)s"

#: virtinst/virtinstall.py:363
#, python-format
msgid ""
"Requested memory %s MiB is abnormally low. Were you trying to specify GiB?"
msgstr ""
"Затражена меморија %s MiB је необично ниска. Да ли сте покушали да наведете "
"GiB?"

#: virtinst/virtinstall.py:380
msgid "The guest's network configuration may not support PXE"
msgstr "Мрежно подешавање госта можда не подржава PXE"

#: virtinst/virtinstall.py:385
#, python-brace-format
msgid ""
"Using --osinfo {osname}, VM performance may suffer. Specify an accurate OS "
"for optimal results."
msgstr ""
"Коришћењем --osinfo {osname}, перформансе виртуелне машине могу опасти. "
"Наведите тачан ОС за најбоље резултате."

#: virtinst/virtinstall.py:401
#, python-brace-format
msgid "Using {osname} --location {url}"
msgstr "Користи се {osname} --location {url}"

#: virtinst/virtinstall.py:484
#, python-brace-format
msgid "Using default --name {vm_name}"
msgstr "Користи се подразумевано --name {vm_name}"

#: virtinst/virtinstall.py:495
#, python-brace-format
msgid "Using container default --memory {megabytes}"
msgstr "Користи се подразумевана меморија контејнера --memory {megabytes}"

#: virtinst/virtinstall.py:515
#, python-brace-format
msgid "Using {os_name} default --memory {megabytes}"
msgstr "Користи се подразумевана меморија за {os_name} --memory {megabytes}"

#: virtinst/virtinstall.py:528
#, python-brace-format
msgid "Using {os_name} default --disk {disk_options}"
msgstr "Користи се подразумевани диск за {os_name} --disk {disk_options}"

#: virtinst/virtinstall.py:580
#, python-brace-format
msgid ""
"Failed to detect osinfo OS name from install media, using fallback name "
"'{name}'.\n"
"Please file a bug against virt-install if you expected the detection to "
"succeed."
msgstr ""
"Није успело откривање osinfo назива оперативног система са инсталационог "
"медијума, користи се резервни назив „{name}“.\n"
"Пријавите грешку за virt-install ако сте очекивали да откривање успе."

#: virtinst/virtinstall.py:587
#, python-format
msgid "Error validating install location: %s"
msgstr "Грешка при потврђивању инсталационог места: %s"

#: virtinst/virtinstall.py:589
msgid ""
"--osinfo/--os-variant OS name is required, but no value was\n"
"set or detected."
msgstr ""
"--osinfo/--os-variant назив ОС-а је обавезан, али вредност\n"
"није постављена нити откривена."

#: virtinst/virtinstall.py:600
msgid ""
"This is now a fatal error. Specifying an OS name is required\n"
"for modern, performant, and secure virtual machine defaults.\n"
msgstr ""
"Ово је сада кобна грешка. Навођење назива ОС-а је обавезно за савремене,\n"
"делотворне и безбедне подразумеване вредности виртуелне машине.\n"

#: virtinst/virtinstall.py:605
msgid ""
"If you expected virt-install to detect an OS name from the\n"
"install media, you can set a fallback OS name with:\n"
"\n"
"  --osinfo detect=on,name=OSNAME\n"
msgstr ""
"Ако сте очекивали да virt-install открије назив ОС-а са инсталационог\n"
"медијума, можете поставити резервни назив ОС-а помоћу:\n"
"\n"
"--osinfo detect=on,name=OSNAME\n"

#: virtinst/virtinstall.py:615
msgid ""
"You can see a full list of possible OS name values with:\n"
"\n"
"   virt-install --osinfo list\n"
msgstr ""
"Можете видети потпуни списак могућих вредности назива ОС-а помоћу:\n"
"\n"
"   virt-install --osinfo list\n"

#: virtinst/virtinstall.py:622
#, python-brace-format
msgid ""
"If your Linux distro is not listed, try one of generic values\n"
"such as: {oslist}\n"
msgstr ""
"Ако ваша Линукс дистрибуција није на списку, покушајте са неком\n"
"од општих вредности као што су: {oslist}\n"

#: virtinst/virtinstall.py:629
#, python-brace-format
msgid ""
"If you just need to get the old behavior back, you can use:\n"
"\n"
"  --osinfo detect=on,require=off\n"
"\n"
"Or export {env_var}=1\n"
msgstr ""
"Ако само желите да вратите старо понашање, можете користити:\n"
"\n"
"  --osinfo detect=on,require=off\n"
"\n"
"Или извезите {env_var}=1\n"

#: virtinst/virtinstall.py:639
#, python-brace-format
msgid "{env_var} set. Skipping fatal error."
msgstr "{env_var} је постављено. Прескачем кобну грешку."

#: virtinst/virtinstall.py:723
