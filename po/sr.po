msgid_plural "Waiting %(minutes)d minutes for the installation to complete."
msgstr[0] "Чекам %(minutes)d минут да се инсталација заврши."
msgstr[1] "Чекам %(minutes)d минута да се инсталација заврши."
msgstr[2] "Чекам %(minutes)d минута да се инсталација заврши."

#: virtinst/virtinstall.py:787
