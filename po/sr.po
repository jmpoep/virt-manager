#: virtManager/vmwindow.py:545
msgid "Save Virtual Machine Screenshot"
msgstr "Сачувај снимак екрана виртуелне машине"

#: virtManager/vmwindow.py:546
msgid "PNG files"
msgstr "ПНГ датотеке"

#: virtManager/vmwindow.py:548
msgid "_Save"
msgstr "_Сачувај"

#: virtManager/xmleditor.py:131 virtManager/xmleditor.py:144
msgid "There are unapplied changes."
msgstr "Постоје непримењене измене."

#: virtManager/xmleditor.py:132
msgid "Your changes will be lost if you leave this tab. Really leave this tab?"
msgstr ""
"Ваше измене ће бити изгубљене ако напустите ову картицу. Заиста желите да је "
"напустите?"

#: virtManager/xmleditor.py:145
msgid ""
"Your XML changes will be lost if you leave this tab. Really leave this tab?"
msgstr ""
"Ваше XML измене ће бити изгубљене ако напустите ову картицу. Заиста желите "
"да је напустите?"

#: virtinst/capabilities.py:300
#, python-format
msgid ""
"Host does not support virtualization type '%(virttype)s' for architecture "
"'%(arch)s'"
msgstr ""
"Домаћин не подржава врсту виртуелизације „%(virttype)s“ за архитектуру „%"
"(arch)s“"

#: virtinst/capabilities.py:305
#, python-format
msgid ""
"Host does not support any virtualization options for architecture '%(arch)s'"
msgstr ""
"Домаћин не подржава ниједну могућност виртуелизације за архитектуру „%(arch)s"
"“"

#: virtinst/capabilities.py:309
#, python-format
msgid "Host does not support virtualization type '%(virttype)s'"
msgstr "Домаћин не подржава врсту виртуелизације „%(virttype)s“"

#: virtinst/capabilities.py:313
msgid "Host does not support any virtualization options"
msgstr "Домаћин не подржава ниједну могућност виртуелизације"

#: virtinst/capabilities.py:320
#, python-format
msgid ""
"Host does not support domain type %(domain)s with machine '%(machine)s' for "
"virtualization type '%(virttype)s' with architecture '%(arch)s'"
msgstr ""
"Домаћин не подржава врсту домена %(domain)s са машином „%(machine)s“ за "
"врсту виртуелизације „%(virttype)s“ са архитектуром „%(arch)s“"

#: virtinst/capabilities.py:331
#, python-format
msgid ""
"Host does not support domain type %(domain)s for virtualization type "
"'%(virttype)s' with architecture '%(arch)s'"
msgstr ""
"Домаћин не подржава врсту домена %(domain)s за врсту виртуелизације „%"
"(virttype)s“ са архитектуром „%(arch)s“"

#: virtinst/cli.py:115
msgid "See man page for examples and full option syntax."
msgstr "Погледајте man страницу за примере и потпуну синтаксу опција."

#: virtinst/cli.py:118
msgid "Use '--option=?' or '--option help' to see available suboptions"
msgstr "Користите „--option=?“ или „--option help“ да видите доступне подопције"

#: virtinst/cli.py:295
#, python-format
msgid ""
"Domain installation does not appear to have been successful.\n"
"If it was, you can restart your domain by running:\n"
"  %s\n"
"otherwise, please restart your installation."
msgstr ""
"Инсталација домена изгледа није била успешна.\n"
"Ако јесте, можете поново покренути домен извршавањем:\n"
"  %s\n"
"у супротном, поново покрените инсталацију."

#: virtinst/cli.py:316
#, python-format
msgid ""
"%(path)s may not be accessible by the hypervisor. You will need to grant the "
"'%(user)s' user search permissions for the following directories: %(dirs)s"
msgstr ""
"%(path)s можда није приступачна хипервизору. Мораћете да доделите кориснику "
"„%(user)s“ овлашћења претраге за следеће директоријуме: %(dirs)s"

#: virtinst/cli.py:329
#, python-format
msgid " (Use --check %s=off or --check all=off to override)"
msgstr " (Користите --check %s=off или --check all=off за преклапање)"

#: virtinst/cli.py:360
#, python-format
msgid "This will overwrite the existing path '%s'"
msgstr "Ово ће преписати постојећу путању „%s“"

#: virtinst/cli.py:370
#, python-format
msgid "Disk %(path)s is already in use by other guests %(names)s."
msgstr "Диск %(path)s већ користе други гости %(names)s."

#: virtinst/cli.py:414
#, python-format
msgid "Running graphical console command: %(command)s"
msgstr "Покрећем наредбу графичке конзоле: %(command)s"

#: virtinst/cli.py:426
#, python-format
msgid "Running text console command: %(command)s"
msgstr "Покрећем наредбу текстуалне конзоле: %(command)s"

#: virtinst/cli.py:470
#, python-format
msgid "Could not find domain '%(domain)s': %(error)s"
msgstr "Нисам успео да пронађем домен „%(domain)s“: %(error)s"

#. translators: option1 and option2 are command line options,
#. e.g. -a or --disk
#: virtinst/cli.py:490
#, python-format
msgid "Cannot use %(option1)s and %(option2)s at the same time"
msgstr "Не могу да користим %(option1)s и %(option2)s у исто време"

#: virtinst/cli.py:608 virtinst/cli.py:612
msgid "Connect to hypervisor with libvirt URI"
msgstr "Повежите се са хипервизором помоћу libvirt адресе"

#: virtinst/cli.py:635
msgid ""
"Configure guest console auto connect. Example:\n"
"--autoconsole text\n"
"--autoconsole graphical\n"
"--autoconsole none"
msgstr ""
"Подесите аутоматско повезивање конзоле госта. Пример:\n"
"--autoconsole text\n"
"--autoconsole graphical\n"
"--autoconsole none"

#: virtinst/cli.py:646
msgid "Don't automatically try to connect to the guest console"
msgstr "Немој самостално покушавати да се повежеш на конзолу госта"

#: virtinst/cli.py:651
msgid "Don't boot guest after completing install."
msgstr "Немојте подизати систем госта након завршетка инсталације."

#: virtinst/cli.py:658
msgid "Don't check name collision, overwrite any guest with the same name."
msgstr ""
"Немојте проверавати сукоб назива, препишите било ког госта са истим називом."

#: virtinst/cli.py:665
msgid "Print the generated domain XML rather than create the guest."
msgstr "Испишите генерисани XML домена уместо да направите госта."

#: virtinst/cli.py:685
msgid ""
"Run through install process, but do not create devices or define the guest."
msgstr ""
"Прођите кроз процес инсталације, али немојте правити уређаје нити дефинисати "
"госта."

#: virtinst/cli.py:693
msgid ""
"Enable or disable validation checks. Example:\n"
"--check path_in_use=off\n"
"--check all=off"
msgstr ""
"Омогућите или онемогућите провере потврђивања. Пример:\n"
"--check path_in_use=off\n"
"--check all=off"

#: virtinst/cli.py:698
msgid "Suppress non-error output"
msgstr "Потисни излаз који није грешка"

#: virtinst/cli.py:699
msgid "Print debugging information"
msgstr "Одштампај податке о отклањању грешака"

#: virtinst/cli.py:708
msgid ""
"Configure guest metadata. Ex:\n"
"--metadata name=foo,title=\"My pretty title\",uuid=...\n"
"--metadata description=\"My nice long description\""
msgstr ""
"Подесите метаподатке госта. Нпр:\n"
"--metadata name=foo,title=\"Мој лепи наслов\",uuid=...\n"
"--metadata description=\"Мој лепи дуги опис\""

#: virtinst/cli.py:721
msgid ""
"Configure guest memory allocation. Ex:\n"
"--memory 1024 (in MiB)\n"
"--memory memory=1024,currentMemory=512\n"
msgstr ""
"Подесите доделу меморије госта. Нпр:\n"
"--memory 1024 (у MiB)\n"
"--memory memory=1024,currentMemory=512\n"

#: virtinst/cli.py:738
msgid ""
"Number of vCPUs to configure for your guest. Ex:\n"
"--vcpus 5\n"
"--vcpus 5,maxvcpus=10,cpuset=1-4,6,8\n"
"--vcpus sockets=2,cores=4,threads=2"
msgstr ""
"Број vCPU-ова за подешавање вашег госта. Нпр:\n"
"--vcpus 5\n"
"--vcpus 5,maxvcpus=10,cpuset=1-4,6,8\n"
"--vcpus sockets=2,cores=4,threads=2"

#: virtinst/cli.py:751
msgid ""
"CPU model and features. Ex:\n"
"--cpu coreduo,+x2apic\n"
"--cpu host-passthrough\n"
msgstr ""
"Модел и могућности процесора. Нпр:\n"
"--cpu coreduo,+x2apic\n"
"--cpu host-passthrough\n"

#: virtinst/cli.py:766
msgid ""
"Configure guest display settings. Ex:\n"
"--graphics spice\n"
"--graphics vnc,port=5901,listen=0.0.0.0\n"
"--graphics none\n"
msgstr ""
"Подесите подешавања приказа госта. Нпр:\n"
"--graphics spice\n"
"--graphics vnc,port=5901,listen=0.0.0.0\n"
"--graphics none\n"

#: virtinst/cli.py:781
msgid ""
"Configure a guest network interface. Ex:\n"
"--network bridge=mybr0\n"
"--network network=my_libvirt_virtual_net\n"
"--network network=mynet,model=virtio,mac=00:11...\n"
"--network none\n"
"--network help"
msgstr ""
"Подесите мрежни интерфејс госта. Нпр:\n"
"--network bridge=mybr0\n"
"--network network=my_libvirt_virtual_net\n"
"--network network=mynet,model=virtio,mac=00:11...\n"
"--network none\n"
"--network help"

#: virtinst/cli.py:797
msgid ""
"Configure a guest controller device. Ex:\n"
"--controller type=usb,model=qemu-xhci\n"
"--controller type=scsi,model=virtio-scsi\n"
msgstr ""
"Подесите уређај контролера госта. Нпр:\n"
"--controller type=usb,model=qemu-xhci\n"
"--controller type=scsi,model=virtio-scsi\n"

#: virtinst/cli.py:806
msgid ""
"Configure a guest input device. Ex:\n"
"--input tablet\n"
"--input keyboard,bus=usb"
msgstr ""
"Подесите улазни уређај госта. Нпр:\n"
"--input tablet\n"
"--input keyboard,bus=usb"

#: virtinst/cli.py:809
msgid "Configure a guest serial device"
msgstr "Подесите серијски уређај госта"

#: virtinst/cli.py:811
msgid "Configure a guest parallel device"
msgstr "Подесите паралелни уређај госта"

#: virtinst/cli.py:814
msgid "Configure a guest communication channel"
msgstr "Подесите комуникациони канал госта"

#: virtinst/cli.py:820
msgid "Configure a text console connection between the guest and host"
msgstr "Подесите везу текстуалне конзоле између госта и домаћина"

#: virtinst/cli.py:826
msgid "Configure physical USB/PCI/etc host devices to be shared with the guest"
msgstr "Подесите физичке УСБ/ПЦИ/итд. уређаје домаћина за дељење са гостом"

#: virtinst/cli.py:836
msgid ""
"Pass host directory to the guest. Ex: \n"
"--filesystem /my/source/dir,/dir/in/guest\n"
"--filesystem template_name,/,type=template"
msgstr ""
"Проследите директоријум домаћина госту. Нпр.:\n"
"--filesystem /моја/изворна/фасцикла,/фасцикла/унутар/госта\r\n"
"--filesystem template_name,/,type=template"

#: virtinst/cli.py:846
msgid "Configure guest sound device emulation"
msgstr "Подесите опонашање звучног уређаја госта"

#: virtinst/cli.py:856
msgid "Configure host audio backend for sound devices"
msgstr "Подесите позадинца звука домаћина за звучне уређаје"

#: virtinst/cli.py:860
msgid "Configure a guest watchdog device"
msgstr "Подесите чуваркућа уређај госта"

#: virtinst/cli.py:862
msgid "Configure guest video hardware."
msgstr "Подесите видео хардвер госта."

#: virtinst/cli.py:867
msgid ""
"Configure a guest smartcard device. Ex:\n"
"--smartcard mode=passthrough"
msgstr ""
"Подесите паметну картицу госта. Нпр:\n"
"--smartcard mode=passthrough"

#: virtinst/cli.py:874
msgid ""
"Configure a guest redirection device. Ex:\n"
"--redirdev usb,type=tcp,server=192.168.1.1:4000"
msgstr ""
"Подесите уређај за преусмеравање госта. Нпр:\n"
"--redirdev usb,type=tcp,server=192.168.1.1:4000"

#: virtinst/cli.py:882
msgid ""
"Configure a guest memballoon device. Ex:\n"
"--memballoon model=virtio"
msgstr ""
"Подесите „memballoon“ уређај госта. Нпр:\n"
"--memballoon model=virtio"

#: virtinst/cli.py:886
msgid ""
"Configure a guest TPM device. Ex:\n"
"--tpm /dev/tpm"
msgstr ""
"Подесите TPM уређај госта. Нпр:\n"
"--tpm /dev/tpm"

#: virtinst/cli.py:890
msgid ""
"Configure a guest RNG device. Ex:\n"
"--rng /dev/urandom"
msgstr ""
"Подесите ГНБ (RNG) уређај госта. Нпр:\n"
"--rng /dev/urandom"

#: virtinst/cli.py:896
msgid ""
"Configure a guest panic device. Ex:\n"
"--panic default"
msgstr ""
"Подесите уређај за панику госта. Нпр:\n"
"--panic default"

#: virtinst/cli.py:902
msgid ""
"Configure a guest shared memory device. Ex:\n"
"--shmem name=shmem0"
msgstr ""
"Подесите уређај дељене меморије госта. Нпр:\n"
"--shmem name=shmem0"

#: virtinst/cli.py:908
msgid ""
"Configure a guest memory device. Ex:\n"
"--memdev dimm,target.size=1024"
msgstr ""
"Подесите меморијски уређај госта. Нпр:\n"
"--memdev dimm,target.size=1024"

#: virtinst/cli.py:914
msgid ""
"Configure guest vsock sockets. Ex:\n"
"--vsock cid.auto=yes\n"
"--vsock cid.address=7"
msgstr ""
"Подесите vsock прикључке госта. Нпр:\n"
"--vsock cid.auto=yes\r\n"
"--vsock cid.address=7"

#: virtinst/cli.py:920
msgid ""
"Configure an IOMMU device. Ex:\n"
"--iommu model=intel,driver.aw_bits=48"
msgstr ""
"Подесите IOMMU уређај госта. Нпр:\n"
"--iommu model=intel,driver.aw_bits=48"

#: virtinst/cli.py:927
msgid ""
"Configure a nvram storage device.\n"
"It's for guest kernel to record oops/panic logs. Ex:\n"
"--pstore backend=acpi-erst,size=8"
msgstr ""
"Подесите nvram уређај за складиштење.\n"
"Служи за то да језгро госта бележи oops/panic записе. Нпр:\n"
"--pstore backend=acpi-erst,size=8"

#: virtinst/cli.py:939
msgid "Set domain <iothreads> and <iothreadids> configuration."
msgstr "Подесите <iothreads> и <iothreadids> подешавања домена."

#: virtinst/cli.py:944
msgid "Set domain seclabel configuration."
msgstr "Подесите seclabel подешавање домена."

#: virtinst/cli.py:951
msgid "Set guest to perform the S390 cryptographic key management operations."
msgstr ""
"Подесите госта да извршава S390 криптографске радње управљања кључевима."

#: virtinst/cli.py:956
msgid "Tune CPU parameters for the domain process."
msgstr "Подесите ЦПЈ параметре за процес домена."

#: virtinst/cli.py:961
msgid "Tune NUMA policy for the domain process."
msgstr "Подесите NUMA политику за процес домена."

#: virtinst/cli.py:966
msgid "Tune memory policy for the domain process."
msgstr "Подесите политику меморије за процес домена."

#: virtinst/cli.py:971
msgid "Tune blkio policy for the domain process."
msgstr "Подесите blkio политику за процес домена."

#: virtinst/cli.py:979
msgid ""
"Set memory backing policy for the domain process. Ex:\n"
"--memorybacking hugepages=on"
msgstr ""
"Подесите политику меморијске подршке за процес домена. Нпр:\n"
"--memorybacking hugepages=on"

#: virtinst/cli.py:988
msgid ""
"Set domain <features> XML. Ex:\n"
"--features acpi=off\n"
"--features apic=on,apic.eoi=on"
msgstr ""
"Подесите XML за <features> домена. Нпр:\n"
"--features acpi=off\n"
"--features apic=on,apic.eoi=on"

#: virtinst/cli.py:998
msgid ""
"Set domain <clock> XML. Ex:\n"
"--clock offset=localtime,rtc_tickpolicy=catchup"
msgstr ""
"Подесите XML за <clock> домена. Нпр:\n"
"--clock offset=localtime,rtc_tickpolicy=catchup"

#: virtinst/cli.py:1002
msgid "Configure VM power management features"
msgstr "Подесите могућности управљања напајањем ВМ-а"

#: virtinst/cli.py:1006
msgid "Configure VM lifecycle management policy"
msgstr "Подесите политику управљања животним циклусом ВМ-а"

#: virtinst/cli.py:1011
msgid "Configure VM resource partitioning (cgroups)"
msgstr "Подесите партиционисање ресурса ВМ-а (cgroups)"

#: virtinst/cli.py:1019
msgid ""
"Configure SMBIOS System Information. Ex:\n"
"--sysinfo host\n"
"--sysinfo bios.vendor=MyVendor,bios.version=1.2.3,...\n"
msgstr ""
"Подесите SMBIOS системске податке. Нпр:\n"
"--sysinfo host\n"
"--sysinfo bios.vendor=MyVendor,bios.version=1.2.3,...\n"

#: virtinst/cli.py:1030
msgid ""
"Pass arguments directly to the QEMU emulator. Ex:\n"
"--qemu-commandline='-display gtk,gl=on'\n"
"--qemu-commandline env=DISPLAY=:0.1"
msgstr ""
"Проследите аргументе директно QEMU емулатору. Нпр:\n"
"--qemu-commandline='-display gtk,gl=on'\n"
"--qemu-commandline env=DISPLAY=:0.1"

#: virtinst/cli.py:1042
msgid ""
"Configure VM launch security (e.g. SEV memory encryption). Ex:\n"
"--launchSecurity sev"
msgstr ""
"Подесите безбедност покретања ВМ-а (нпр. SEV шифровање меморије). Нпр:\n"
"--launchSecurity sev"

#: virtinst/cli.py:1054
msgid ""
"Configure guest boot settings. Ex:\n"
"--boot hd,cdrom,menu=on\n"
"--boot init=/sbin/init (for containers)"
msgstr ""
"Подесите подешавања подизања госта. Нпр:\n"
"--boot hd,cdrom,menu=on\n"
"--boot init=/sbin/init (за контејнере)"

#: virtinst/cli.py:1065
msgid ""
"Enable user namespace for LXC container. Ex:\n"
"--idmap uid.start=0,uid.target=1000,uid.count=10"
msgstr ""
"Омогућите кориснички именски простор за LXC контејнер. Нпр:\n"
"--idmap uid.start=0,uid.target=1000,uid.count=10"

#: virtinst/cli.py:1080
msgid ""
"Specify storage with various options. Ex.\n"
"--disk size=10 (new 10GiB image in default location)\n"
"--disk /my/existing/disk,cache=none\n"
"--disk device=cdrom,bus=scsi\n"
"--disk=?"
msgstr ""
"Наведите складиште са разним опцијама. Нпр.\n"
"--disk size=10 (нови одраз од 10GiB на подразумеваном месту)\n"
"--disk /my/existing/disk,cache=none\n"
"--disk device=cdrom,bus=scsi\n"
"--disk=?"

#: virtinst/cli.py:1091
msgid "OS options"
msgstr "Могућности ОС-а"

#: virtinst/cli.py:1094
msgid "The OS being installed in the guest."
msgstr "ОС који се инсталира на госту."

#: virtinst/cli.py:1096
msgid "The OS installed in the guest."
msgstr "ОС инсталиран на госту."

#: virtinst/cli.py:1099
msgid ""
"This is used for deciding optimal defaults like VirtIO.\n"
"Example values: fedora29, rhel7.0, win10, ...\n"
"Use '--osinfo list' to see a full list."
msgstr ""
"Ово се користи за одређивање оптималних подразумеваних вредности као што је "
"ВиртИО.\n"
"Примери вредности: fedora29, rhel7.0, win10, ...\n"
"Користите „--osinfo list“ да бисте видели цео списак."

#: virtinst/cli.py:1115
msgid ""
"Perform raw XML XPath options on the final XML. Example:\n"
"--xml ./cpu/@mode=host-passthrough\n"
"--xml ./devices/disk[2]/serial=new-serial\n"
"--xml xpath.delete=./clock"
msgstr ""
"Извршите сирове XML XPath опције на коначном XML-у. Пример:\n"
"--xml ./cpu/@mode=host-passthrough\n"
"--xml ./devices/disk[2]/serial=new-serial\n"
"--xml xpath.delete=./clock"

#: virtinst/cli.py:1148
#, python-format
msgid "%(key)s must be 'yes' or 'no'"
msgstr "%(key)s мора бити „yes“ (да) или „no“ (не)"

#: virtinst/cli.py:1343
#, python-format
msgid ""
"Don't know how to match device type '%(device_type)s' property "
"'%(property_name)s'"
msgstr ""
"Не знам како да упарим својство „%(property_name)s“ врсте уређаја „%"
"(device_type)s“"

#: virtinst/cli.py:1673
#, python-format
msgid "Unknown %(optionflag)s options: %(string)s"
msgstr "Непознате %(optionflag)s опције: %(string)s"

#: virtinst/cli.py:1729 virtinst/cli.py:1760
#, python-format
msgid "Error: %(cli_flag_name)s %(options)s: %(err)s"
msgstr "Грешка: %(cli_flag_name)s %(options)s: %(err)s"

#: virtinst/cli.py:2193
msgid "No display detected. Not running virt-viewer."
msgstr "Није откривен приказ. Не покрећем virt-viewer."

#: virtinst/cli.py:2199
msgid ""
"Unable to connect to graphical console: virt-viewer not installed. Please "
"install the 'virt-viewer' package."
msgstr ""
